{
  "name": "@vijaynkw/mcp-router",
  "version": "1.0.0",
  "description": "Smart MCP router — four modes (router, delegated, passthrough, smart) with support for Anthropic Claude, Ollama, Groq, and any OpenAI-compatible provider",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "mcp-router": "dist/index.js",
    "@vijaynkw/mcp-router": "dist/index.js"
  },
  "files": [
    "dist/**/*"
  ],
  "scripts": {
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "clean": "rimraf dist",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "claude",
    "anthropic",
    "ai",
    "llm",
    "router",
    "windsurf",
    "cursor"
  ],
  "author": "Vijaynw <vijaywaghmare713@gmail.com>",
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.54.0",
    "@modelcontextprotocol/sdk": "^1.11.0",
    "express": "^4.21.2",
    "openai": "^6.38.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.0",
    "rimraf": "^6.0.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
